# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local: mongodb://localhost:27017/chatbot_search_product
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/chatbot_search_product
MONGO_URI=mongodb://localhost:27017/chatbot_search_product

# JWT secret — change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# AI microservice URL (Python FastAPI service)
AI_SERVICE_URL=http://localhost:8000

# CORS — frontend origin
CLIENT_URL=http://localhost:3000
