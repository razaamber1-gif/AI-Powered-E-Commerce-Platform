# Ollama runtime location (default Ollama port is 11434)
OLLAMA_HOST=http://localhost:11434

# Which model to use. Pull it first with: ollama pull llama3.2:3b
# Alternatives: phi3:mini (smaller, faster), llama3.1:8b (better, needs 16GB+ RAM)
MODEL_NAME=llama3.2:3b

# Timeout in seconds for LLM calls (CPU inference can be slow on first call)
LLM_TIMEOUT=60

# Port the FastAPI service listens on
AI_SERVICE_PORT=8000
